{
  "appId": "com.lingjing.desktop",
  "productName": "Lingjing",
  "icon": "build/icon.png",
  "directories": {
    "output": "artifacts/pc-beta"
  },
  "files": [
    "apps/pc-app/runtime/**/*",
    "package.json"
  ],
  "asar": true,
  "extraMetadata": {
    "main": "apps/pc-app/runtime/main.cjs"
  },
  "win": {
    "target": [
      {
        "target": "portable",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "build/icon.png",
    "artifactName": "Lingjing-${version}-portable-${arch}.${ext}"
  }
}
