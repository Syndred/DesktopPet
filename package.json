{
  "name": "qingpet-lord-3d",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo baseline for QingPet Lord 3D",
  "workspaces": [
    "apps/pc-app",
    "apps/supabase-edge",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:unit": "vitest run -c vitest.unit.config.ts",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:e2e": "vitest run -c vitest.e2e.config.ts",
    "test:performance": "vitest run -c vitest.performance.config.ts",
    "test:security": "vitest run -c vitest.security.config.ts",
    "test:layers": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:performance && npm run test:security",
    "test:coverage": "vitest run --coverage",
    "release:build:pc": "node scripts/release/build-pc.mjs",
    "release:build:mobile": "node scripts/release/build-mobile.mjs",
    "release:build": "npm run release:build:pc && npm run release:build:mobile",
    "release:sign": "node scripts/release/sign-artifacts.mjs",
    "release:manifest": "node scripts/release/create-release-manifest.mjs",
    "release:prepare": "npm run release:build && npm run release:sign && npm run release:manifest",
    "release:rollback": "node scripts/release/rollback-release.mjs",
    "dev:pc": "node scripts/desktop/run-electron.cjs apps/pc-app/runtime",
    "start:pc": "node scripts/desktop/run-electron.cjs apps/pc-app/runtime",
    "pc:smoke": "node scripts/smoke/check-pc-runtime.mjs",
    "dr:backup": "node scripts/dr/backup-state.mjs",
    "dr:restore": "node scripts/dr/restore-state.mjs",
    "perf:report": "node scripts/perf/generate-weekly-report.mjs",
    "test:watch": "vitest",
    "verify": "npm run lint && npm run typecheck && npm run test:layers"
  },
  "config": {
    "electron_mirror": "https://npmmirror.com/mirrors/electron/"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "@vitest/coverage-v8": "^3.0.9",
    "electron": "^36.9.5",
    "eslint": "^8.57.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/model-viewer": "^4.1.0",
    "@supabase/supabase-js": "^2.57.4",
    "ws": "^8.19.0"
  }
}
